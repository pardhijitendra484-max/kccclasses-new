# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/kccclasses

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_minimum_32_characters_long

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=https://your-railway-domain.up.railway.app
APP_NAME=KCC Classes

# ── SendGrid Email ────────────────────────────────────────────────────────────
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# This email MUST be verified in SendGrid as a Single Sender
SENDER_EMAIL=noreply@yourdomain.com
# Admin receives contact form submissions and new registration alerts
ADMIN_EMAIL=admin@yourdomain.com
