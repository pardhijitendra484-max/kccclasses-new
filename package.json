{
  "name": "kcc-classes",
  "version": "1.0.0",
  "description": "KCC Classes - Full Stack Website",
  "main": "server/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start":       "node server/server.js",
    "build":       "npm install --prefix client && npm run build --prefix client",
    "dev":         "concurrently \"nodemon server/server.js\" \"npm run dev --prefix client\"",
    "seed":        "node server/seed.js"
  },
  "dependencies": {
    "@sendgrid/mail":  "^8.1.6",
    "bcryptjs":        "^2.4.3",
    "cookie-parser":   "^1.4.6",
    "cors":            "^2.8.5",
    "dotenv":          "^16.3.1",
    "express":         "^4.18.2",
    "jsonwebtoken":    "^9.0.2",
    "mongoose":        "^8.0.3",
    "multer":          "^1.4.5-lts.1",
    "nodemailer":      "^6.9.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon":      "^3.0.2"
  }
}
